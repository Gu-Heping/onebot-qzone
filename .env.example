# ===== 登录（二选一或组合）=====
# 方式一：Cookie 字符串（推荐）。从浏览器登录 QQ 空间后，F12 → Application → Cookies → user.qzone.qq.com，复制为 name1=value1; name2=value2
# 必须包含：uin、p_uin、skey、p_skey（可再带 RK、ptcz 等）
QZONE_COOKIE_STRING=
# 兼容旧变量名
QZONE_COOKIE=

# 方式二：二维码扫码（Playwright 浏览器）。未配置 Cookie 或 Cookie 失效时，会启动浏览器生成二维码到 QZONE_CACHE_PATH/qrcode.png，用手机 QQ 扫码
# 1=启用，0=禁用（默认）
QZONE_ENABLE_QR=0

# Cookie/二维码/缓存目录（登录成功会在此保存 cookies.json，下次启动自动复用）
QZONE_CACHE_PATH=./test_cache
# 是否保存调试用 dump 文件
QZONE_DEBUG_DUMP=0

# ===== OneBot 服务端配置 =====
# HTTP API 监听地址和端口
ONEBOT_HOST=0.0.0.0
ONEBOT_PORT=5700
# 访问令牌（为空则不鉴权）
ONEBOT_ACCESS_TOKEN=

# ===== OneBot 事件上报 =====
# HTTP POST 上报地址（多个用逗号分隔）
ONEBOT_HTTP_POST_URLS=
# WebSocket Reverse（反向 WS）地址（多个用逗号分隔）
ONEBOT_WS_REVERSE_URLS=
# 反向 WS 分离模式（可选，不设则用上面的 Universal 连接）
ONEBOT_WS_REVERSE_API_URLS=
ONEBOT_WS_REVERSE_EVENT_URLS=
# 反向 WS 重连间隔（毫秒）
ONEBOT_WS_REVERSE_RECONNECT_INTERVAL=3000

# ===== 轮询配置 =====
# 说说轮询间隔（秒），建议 >= 30 避免触发限流
ONEBOT_POLL_INTERVAL=30
# 轮询数据源: auto / pc / mobile
ONEBOT_EVENT_POLL_SOURCE=auto
# 是否将说说作为 message 事件上报
ONEBOT_EMIT_MESSAGE_EVENTS=1
# 是否上报评论事件
ONEBOT_EMIT_COMMENT_EVENTS=1
# 评论轮询间隔（秒）
ONEBOT_COMMENT_POLL_INTERVAL=30
# 是否上报点赞事件（较消耗 API 配额）
ONEBOT_EMIT_LIKE_EVENTS=0
# 点赞轮询间隔（秒）
ONEBOT_LIKE_POLL_INTERVAL=60
# 调试模式（输出详细事件日志）
ONEBOT_EVENT_DEBUG=0
